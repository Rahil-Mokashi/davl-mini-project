    let durationMinutes = Math.round(3 + Math.pow(Math.random(), 1.35) * 240)
    if (Math.random() < 0.035) {
      durationMinutes = Math.round(380 + Math.random() * 3600)
    }
    durationMinutes = Math.max(1, durationMinutes)
    const severity = 1 + Math.floor(Math.random() * 10)
    const noise = (mag: number) => (Math.random() - 0.5) * mag
    const dataLossGb = Math.max(
      0.02,
      12 + severity * 5.5 + durationMinutes * 0.035 + noise(22) + Math.pow(Math.random(), 1.4) * 35,
    )
    const costKUsd = Math.max(
      0.15,
      6 + severity * 4.2 + dataLossGb * 0.42 + durationMinutes * 0.055 + noise(18) + Math.random() * 28,
    )
    const c = COUNTRIES[Math.floor(Math.random() * COUNTRIES.length)]!
    events.push({
      id: `evt-${i}`,
      attackType: types[Math.floor(Math.random() * types.length)]!,
        
  // FilteredChartsPanel content removed; charts are rendered in `App()` directly.
}

function defaultDateRange(): { start: string; end: string } {
  const end = new Date()
  const start = new Date(end)
  start.setDate(start.getDate() - 30)
  const toIso = (d: Date) => d.toISOString().slice(0, 10)
  return { start: toIso(start), end: toIso(end) }
}

