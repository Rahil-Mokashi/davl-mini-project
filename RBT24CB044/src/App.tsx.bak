}

type BoxFenceStats = { q1: number; q3: number; iqr: number; lower: number; upper: number }

function quantileSorted(sorted: number[], q: number): number {
  const n = sorted.length
  if (n === 0) return 0
  const pos = (n - 1) * q
  const lo = Math.floor(pos)
  const hi = Math.ceil(pos)
  if (lo === hi) return sorted[lo]!
  return sorted[lo]! + (pos - lo) * (sorted[hi]! - sorted[lo]!)
}

function boxFenceStats(sorted: number[]): BoxFenceStats | null {
  if (sorted.length === 0) return null
  const q1 = quantileSorted(sorted, 0.25)
  const q3 = quantileSorted(sorted, 0.75)
  const iqr = q3 - q1
  const lower = q1 - 1.5 * iqr
  const upper = q3 + 1.5 * iqr
  return { q1, q3, iqr, lower, upper }
}

function isFenceOutlier(value: number, stats: BoxFenceStats): boolean {
  if (stats.iqr <= 0) return false
  return value < stats.lower || value > stats.upper
}

function boxPointHoverHtml(value: number, stats: BoxFenceStats, kind: 'severity' | 'duration'): string {
  const fmt = (n: number) => (kind === 'duration' ? `${Math.round(n)} min` : String(Math.round(n * 10) / 10))
  const out = isFenceOutlier(value, stats)
  const fence = `Q1 ${fmt(stats.q1)}, Q3 ${fmt(stats.q3)}, IQR ${fmt(stats.iqr)} · fences ${fmt(stats.lower)}–${fmt(stats.upper)}`
  if (!out) {
    return `${fence}<br><span style="color:#4ade80">Inside 1.5×IQR whiskers — not flagged.</span>`
  }
  const dir = value < stats.lower ? 'below the lower fence' : 'above the upper fence'
  return `${fence}<br><b style="color:#fb7185">Outlier</b> (${dir}): outside Q1−1.5×IQR or Q3+1.5×IQR — often rare tail events, long-running incidents, or data you should triage.`
}

function parseISODateLocal(s: string): number {
  const [y, m, d] = s.split('-').map(Number)
  return new Date(y, m - 1, d).getTime()
}

function endOfDayLocal(iso: string): number {
  return parseISODateLocal(iso) + 86400000 - 1
}

function formatLocalISODate(d: Date): string {
  const y = d.getFullYear()
  const m = String(d.getMonth() + 1).padStart(2, '0')
  const day = String(d.getDate()).padStart(2, '0')
  return `${y}-${m}-${day}`
}

function formatCompact(n: number): string {
  return n.toLocaleString(undefined, { maximumFractionDigits: 0 })
}

function mean(nums: number[]): number {
  if (nums.length === 0) return 0
  return nums.reduce((s, x) => s + x, 0) / nums.length
}

function pearsonCorrelation(a: number[], b: number[]): number {
  const n = a.length
  if (n < 2 || b.length !== n) return 0
  const ma = mean(a)
  const mb = mean(b)
  let cov = 0
  let va = 0
  let vb = 0
  for (let i = 0; i < n; i++) {
    const da = a[i]! - ma
    const db = b[i]! - mb
    cov += da * db
    va += da * da
    vb += db * db
  }
  const den = Math.sqrt(va * vb)
  return den === 0 ? 0 : cov / den
}

function correlationMatrix(cols: number[][]): number[][] {
  const k = cols.length
  return Array.from({ length: k }, (_, i) =>
    Array.from({ length: k }, (_, j) => pearsonCorrelation(cols[i]!, cols[j]!)),
  )
}

