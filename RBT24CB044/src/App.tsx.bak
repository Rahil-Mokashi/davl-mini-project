function ThemeToggle({ isDark, onToggle }: { isDark: boolean; onToggle: () => void }) {
  return (
    <button
      type="button"
      onClick={onToggle}
      className="flex size-10 items-center justify-center rounded-lg border border-zinc-200 bg-white text-zinc-600 shadow-sm transition hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700"
      aria-label={isDark ? 'Switch to light theme' : 'Switch to dark theme'}
    >
      {isDark ? (
        <svg className="size-5" fill="none" viewBox="0 0 24 24" strokeWidth={1.5} stroke="currentColor" aria-hidden>
          <path strokeLinecap="round" strokeLinejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
      ) : (
        <svg className="size-5" fill="none" viewBox="0 0 24 24" strokeWidth={1.5} stroke="currentColor" aria-hidden>
          <path strokeLinecap="round" strokeLinejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      )}
    </button>
  )
}

type KpiTone = 'cyan' | 'amber' | 'rose' | 'violet'

const kpiToneClass: Record<
  KpiTone,
  { box: string; icon: string }
> = {
  cyan: {
    box: 'bg-cyan-500/10 ring-cyan-500/20 dark:bg-cyan-500/15 dark:ring-cyan-400/20',
    icon: 'text-cyan-600 dark:text-cyan-400',
  },
  amber: {
    box: 'bg-amber-500/10 ring-amber-500/20 dark:bg-amber-500/15 dark:ring-amber-400/20',
    icon: 'text-amber-600 dark:text-amber-400',
  },
  rose: {
    box: 'bg-rose-500/10 ring-rose-500/20 dark:bg-rose-500/15 dark:ring-rose-400/20',
    icon: 'text-rose-600 dark:text-rose-400',
  },
  violet: {
    box: 'bg-violet-500/10 ring-violet-500/20 dark:bg-violet-500/15 dark:ring-violet-400/20',
    icon: 'text-violet-600 dark:text-violet-400',
  },
}

function KpiCard({
  title,
  value,
  subtext,
  trend,
  trendSentiment = 'neutral',
  tone,
  icon,
}: {
  title: string
  value: string
  subtext: string
  trend?: string
  trendSentiment?: 'positive' | 'negative' | 'neutral'
  tone: KpiTone
  icon: ReactNode
}) {
  const t = kpiToneClass[tone]
  const trendCls =
    trendSentiment === 'neutral'
      ? 'text-zinc-500 dark:text-zinc-400'
      : trendSentiment === 'positive'
        ? 'text-emerald-600 dark:text-emerald-400'
        : 'text-rose-600 dark:text-rose-400'

  return (
    <div className="group relative overflow-hidden rounded-2xl border border-zinc-200/90 bg-white p-4 shadow-sm ring-1 ring-black/[0.02] transition hover:border-zinc-300/90 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900/70 dark:ring-white/[0.04] dark:hover:border-zinc-700 sm:p-5">
      <div
        className={`pointer-events-none absolute -right-6 -top-6 size-28 rounded-full opacity-[0.22] blur-2xl transition-opacity group-hover:opacity-40 dark:opacity-[0.14] dark:group-hover:opacity-25 ${
          tone === 'cyan'
            ? 'bg-cyan-400'
            : tone === 'amber'
              ? 'bg-amber-400'
              : tone === 'rose'
                ? 'bg-rose-400'
                : 'bg-violet-400'
        }`}
        aria-hidden
      />

      <div className="relative flex gap-4">
        <div
          className={`flex size-11 shrink-0 items-center justify-center rounded-xl ring-1 sm:size-12 ${t.box}`}
        >
          <span className={t.icon}>{icon}</span>
        </div>
        <div className="min-w-0 flex-1">
          <p className="text-[11px] font-semibold uppercase tracking-[0.08em] text-zinc-500 dark:text-zinc-400">
            {title}
          </p>
          <p className="mt-1.5 text-2xl font-semibold tracking-tight text-zinc-900 tabular-nums dark:text-zinc-50 sm:text-3xl sm:leading-none">
            {value}
          </p>
          <p className="mt-2 text-xs leading-relaxed text-zinc-500 dark:text-zinc-400">{subtext}</p>
          {trend ? (
            <p className={`mt-1 text-xs font-medium ${trendCls}`}>{trend}</p>
          ) : null}
        </div>
      </div>
    </div>
  )
}

type AttackBarTooltipProps = {
  active?: boolean
  payload?: ReadonlyArray<{ value?: unknown; payload?: Record<string, unknown> }>
  label?: unknown
  isDark: boolean
}

function AttackBarTooltip({ active, payload, label, isDark }: AttackBarTooltipProps) {
  if (!active || !payload?.length) return null
  const row = payload[0]
  const p = row?.payload as { attack_type?: string; count?: number } | undefined
  const name = p?.attack_type ?? String(label ?? '')
  const raw = row?.value ?? p?.count ?? 0
  const count = typeof raw === 'number' ? raw : Number(raw)
  return (
    <div
      className={`rounded-lg border px-3 py-2 text-sm shadow-lg backdrop-blur-sm ${
        isDark
          ? 'border-zinc-600 bg-zinc-900/95 text-zinc-100'
          : 'border-zinc-200 bg-white/95 text-zinc-900'
      }`}
    >
      <p className="font-semibold">{name}</p>
      <p className={`mt-0.5 text-xs tabular-nums ${isDark ? 'text-zinc-400' : 'text-zinc-500'}`}>
        {formatCompact(Number.isFinite(count) ? count : 0)} attacks
      </p>
    </div>
  )
}

type TimeSeriesTooltipProps = {
  active?: boolean
  payload?: unknown
  label?: unknown
  isDark: boolean
  valueLabel: string
}

function PieDistributionTooltip({
  active,
  payload,
  isDark,
}: {
  active?: boolean
  payload?: unknown
  isDark: boolean
}) {
  if (!active || !Array.isArray(payload) || !payload.length) return null
  const pl = payload[0] as {
    name?: string
    value?: number
    payload?: { attack_type?: string; count?: number; percent?: number }
  }
  const row = pl.payload
  const name = row?.attack_type ?? pl.name ?? '—'
  const count = row?.count ?? pl.value ?? 0
  const pct = row?.percent
  return (
    <div
      className={`rounded-lg border px-3 py-2 text-sm shadow-lg backdrop-blur-sm ${
        isDark
          ? 'border-zinc-600 bg-zinc-900/95 text-zinc-100'
          : 'border-zinc-200 bg-white/95 text-zinc-900'
      }`}
    >
      <p className="font-semibold">{name}</p>
      <p className={`mt-1 text-xs tabular-nums ${isDark ? 'text-zinc-400' : 'text-zinc-500'}`}>
        {formatCompact(Number.isFinite(Number(count)) ? Number(count) : 0)} attacks
        {typeof pct === 'number' ? ` · ${pct}% of filtered set` : null}
      </p>
    </div>
  )
}

function TimeSeriesTooltip({ active, payload, label, isDark, valueLabel }: TimeSeriesTooltipProps) {
  if (!active || !Array.isArray(payload) || !payload.length) return null
  const row = payload[0] as { value?: unknown; payload?: Record<string, unknown> } | undefined
  if (!row) return null
  const p = row.payload as { date?: string } | undefined
  const dateStr = p?.date ?? String(label ?? '')
  const raw = row?.value
  const n = typeof raw === 'number' ? raw : Number(raw)
  return (
    <div
      className={`rounded-lg border px-3 py-2 text-sm shadow-lg backdrop-blur-sm ${
        isDark
          ? 'border-zinc-600 bg-zinc-900/95 text-zinc-100'
          : 'border-zinc-200 bg-white/95 text-zinc-900'
      }`}
    >
      <p className={`text-xs font-medium ${isDark ? 'text-zinc-400' : 'text-zinc-500'}`}>{dateStr}</p>
      <p className="mt-1 font-semibold tabular-nums">
        {formatCompact(Number.isFinite(n) ? n : 0)} <span className="font-normal opacity-80">{valueLabel}</span>
      </p>
    </div>
  )
}

