  // top-level placeholders are harmless and will be shadowed by inner scope.
  const filteredEvents: MockEvent[] = []
  const isDark = false
  

  

  // FilteredChartsPanel content removed; charts are rendered in `App()` directly.

function App() {
  const [isDark, setIsDark] = useState(true)
  const [activeNav, setActiveNav] = useState<string>('dashboard')
  const [sidebarOpen, setSidebarOpen] = useState(false)

  const [attackType, setAttackType] = useState<AttackTypeOption>('all')
  const [dateStart, setDateStart] = useState(() => defaultDateRange().start)
  const [dateEnd, setDateEnd] = useState(() => defaultDateRange().end)
  const [severityMin, setSeverityMin] = useState(1)
  const [severityMax, setSeverityMax] = useState(10)
  const [allEvents, setAllEvents] = useState<MockEvent[]>([])
  const [isLoading, setIsLoading] = useState(true)

  useEffect(() => {
    let mounted = true
    // simulate async load of events (replace with real fetch as needed)
    setTimeout(() => {
      if (!mounted) return
      setAllEvents(generateMockEvents())
      setIsLoading(false)
    }, 300)
    return () => {
      mounted = false
    }
  }, [])

  useEffect(() => {
    try {
      const root = document.documentElement
      if (isDark) root.classList.add('dark')
      else root.classList.remove('dark')
    } catch (e) {
      // ignore server environments
    }
  }, [isDark])

  const filteredEvents = useMemo(() => {
    const t0 = parseISODateLocal(dateStart)
    const t1 = endOfDayLocal(dateEnd)
    if (t1 < t0) return []

    return allEvents.filter((e) => {
      if (e.at < t0 || e.at > t1) return false
      if (attackType !== 'all' && e.attackType !== attackType) return false
      if (e.severity < severityMin || e.severity > severityMax) return false
      return true
    })
  }, [allEvents, attackType, dateEnd, dateStart, severityMax, severityMin])

  const attacksByCountry = useMemo(() => {
    const m = new Map<string, { iso3: string; country: string; attacks: number }>()
    for (const e of filteredEvents) {
      const iso = e.countryIso3 || 'UNK'
      const name = e.country || iso
      const cur = m.get(iso)
      if (cur) cur.attacks += 1
      else m.set(iso, { iso3: iso, country: name, attacks: 1 })
    }
    return Array.from(m.values()).sort((a, b) => b.attacks - a.attacks)
  }, [filteredEvents])

  const anomaliesSet = useMemo(() => {
    if (filteredEvents.length === 0) return new Set<string>()
    const sev = filteredEvents.map((e) => e.severity).sort((a, b) => a - b)
    const dur = filteredEvents.map((e) => e.durationMinutes).sort((a, b) => a - b)
    const sevStats = boxFenceStats(sev)
    const durStats = boxFenceStats(dur)
    const s = new Set<string>()
    for (const e of filteredEvents) {
      const isSev = sevStats ? isFenceOutlier(e.severity, sevStats) : false
      const isDur = durStats ? isFenceOutlier(e.durationMinutes, durStats) : false
      if (isSev || isDur) s.add(e.id)
    }
    return s
  }, [filteredEvents])
  const [liveSortBy, setLiveSortBy] = useState<'time' | 'severity' | 'dataLoss'>('time')

  const queueRows = useMemo(() => {
    const base = [...filteredEvents]
    if (liveSortBy === 'severity') base.sort((a, b) => b.severity - a.severity || b.at - a.at)
    else if (liveSortBy === 'dataLoss') base.sort((a, b) => b.dataLossGb - a.dataLossGb || b.at - a.at)
    else base.sort((a, b) => b.at - a.at)
    return base.slice(0, 6).map((e) => {
      const sev = e.severity >= 8 ? 'Critical' : e.severity >= 5 ? 'High' : e.severity >= 3 ? 'Medium' : 'Low'
      const mins = Math.max(0, Math.floor((Date.now() - e.at) / 60000))
      const time = mins < 60 ? `${mins}m` : `${Math.floor(mins / 60)}h`
      return { key: e.id, t: `${e.attackType} · ${sev}`, time, isAnomaly: anomaliesSet.has(e.id) }
    })
  }, [filteredEvents, liveSortBy, anomaliesSet])
 

  const threatBars = useMemo(() => {
    const counts = new Array(12).fill(0)
    for (const e of filteredEvents) {
      const h = new Date(e.at).getHours()
      const bin = Math.min(11, Math.floor(h / 2))
      counts[bin]++
    }
    const max = Math.max(1, ...counts)
    return counts.map((c) => Math.max(8, Math.round((c / max) * 100)))
  }, [filteredEvents])

  const threatLabels = ['0h', '2h', '4h', '6h', '8h', '10h', '12h', '14h', '16h', '18h', '20h', '22h']

  const attacksByTypeChart = useMemo(() => {
    const counts = new Map<string, number>()
    for (const t of ATTACK_TYPE_LABELS) counts.set(t, 0)
    for (const e of filteredEvents) {
      counts.set(e.attackType, (counts.get(e.attackType) || 0) + 1)
    }
    return ATTACK_TYPE_LABELS.map((attack_type) => ({
      attack_type,
      count: counts.get(attack_type) ?? 0,
    }))
  }, [filteredEvents])

  const pieChartData = useMemo(() => {
    const rows = attacksByTypeChart.filter((d) => d.count > 0)
    const total = rows.reduce((s, d) => s + d.count, 0) || 1
    return rows.map((d) => ({
      ...d,
      percent: Math.round((d.count / total) * 1000) / 10,
    }))
  }, [attacksByTypeChart])

  const attacksOverTime = useMemo(() => {
    const t0 = parseISODateLocal(dateStart)
    const t1 = parseISODateLocal(dateEnd)
    if (t1 < t0) return []

    const byDay = new Map<string, number>()
    for (let x = t0; x <= t1; x += 86400000) {
      byDay.set(formatLocalISODate(new Date(x)), 0)
    }
    for (const e of filteredEvents) {
      const key = formatLocalISODate(new Date(e.at))
      if (byDay.has(key)) {
        byDay.set(key, (byDay.get(key) || 0) + 1)
      }
    }

    return Array.from(byDay.keys())
      .sort()
      .map((date) => ({ date, attacks: byDay.get(date) ?? 0 }))
  }, [dateEnd, dateStart, filteredEvents])

  const attacksCumulative = useMemo(() => {
    let sum = 0
    return attacksOverTime.map((row) => {
      sum += row.attacks
      return { date: row.date, attacks: row.attacks, cumulative: sum }
    })
  }, [attacksOverTime])

  const chartAxisTick = isDark ? '#a1a1aa' : '#52525b'
  const chartGrid = isDark ? '#3f3f46' : '#e4e4e7'
  const chartCursor = isDark ? 'rgba(39, 39, 42, 0.45)' : 'rgba(24, 24, 27, 0.06)'

  const severityHistogram = useMemo(() => {
    const counts = new Array(10).fill(0)
    for (const e of filteredEvents) {
      const s = Math.min(10, Math.max(1, Math.round(Number(e.severity))))
      counts[s - 1]++
    }
    return counts as number[]
  }, [filteredEvents])

  const severityHistogramChartData = useMemo((): ChartData<'bar'> => {
    const edge = isDark ? '#3f3f46' : '#e4e4e7'
    return {
      labels: [...SEVERITY_BIN_LABELS],
      datasets: [
        {
          label: 'Attacks',
          data: severityHistogram,
          backgroundColor: SEVERITY_HISTOGRAM_FILLS,
          borderColor: edge,
          borderWidth: 1,
          borderRadius: 6,
          borderSkipped: false,
          barPercentage: 1,
          categoryPercentage: 0.9,
        },
      ],
    }
  }, [isDark, severityHistogram])

  const severityHistogramOptions = useMemo((): ChartOptions<'bar'> => {
    const tick = isDark ? '#a1a1aa' : '#52525b'
    const grid = isDark ? 'rgba(63, 63, 70, 0.55)' : 'rgba(228, 228, 231, 0.9)'
    return {
      responsive: true,
      maintainAspectRatio: false,
      animation: {
        duration: 850,
        easing: 'easeOutQuart',
      },
      interaction: {
        mode: 'index',
        intersect: false,
      },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: isDark ? 'rgba(24, 24, 27, 0.94)' : 'rgba(255, 255, 255, 0.97)',
          titleColor: isDark ? '#f4f4f5' : '#18181b',
          bodyColor: isDark ? '#a1a1aa' : '#52525b',
          borderColor: isDark ? '#3f3f46' : '#e4e4e7',
          borderWidth: 1,
          padding: 10,
          cornerRadius: 8,
          displayColors: false,
          callbacks: {
            title: (items) => {
              const label = items[0]?.label
              return `Severity score ${label ?? ''}`
            },
            label: (item) => {
              const raw = item.raw
              const v = typeof raw === 'number' ? raw : Number(raw)
              return `${formatCompact(Number.isFinite(v) ? v : 0)} attacks`
            },
          },
        },
      },
      scales: {
        x: {
          offset: true,
          title: {
            display: true,
            text: 'Severity (1–10)',
            color: tick,
            font: { size: 11, weight: 'bold' },
          },
          ticks: {
            color: tick,
            font: { size: 11 },
          },
          grid: { display: false },
        },
        y: {
          beginAtZero: true,
          title: {
            display: true,
            text: 'Count',
            color: tick,
            font: { size: 11, weight: 'bold' },
          },
          ticks: {
            color: tick,
            precision: 0,
            maxTicksLimit: 9,
          },
          grid: {
            color: grid,
            drawTicks: false,
          },
          border: { display: false },
        },
      },
    }
  }, [isDark])

  const boxPlotFigure = useMemo(() => {
    const n = filteredEvents.length
    if (n === 0) {
      return { data: [] as Data[], layout: {} as Partial<Layout> }
    }

    const sev = filteredEvents.map((e) => e.severity)
    const dur = filteredEvents.map((e) => e.durationMinutes)
    const sevStats = boxFenceStats([...sev].sort((a, b) => a - b))
    const durStats = boxFenceStats([...dur].sort((a, b) => a - b))
    if (!sevStats || !durStats) {
      return { data: [] as Data[], layout: {} as Partial<Layout> }
    }

    const sevCustom = sev.map((v) => boxPointHoverHtml(v, sevStats, 'severity'))
    const durCustom = dur.map((v) => boxPointHoverHtml(v, durStats, 'duration'))
    const sevOut = sev.map((v) => isFenceOutlier(v, sevStats))
    const durOut = dur.map((v) => isFenceOutlier(v, durStats))

    const paper = 'rgba(0,0,0,0)'
    const plot = isDark ? '#18181b' : '#fafafa'
    const fg = isDark ? '#e4e4e7' : '#3f3f46'
    const grid = isDark ? '#27272a' : '#e4e4e7'
    const muted = isDark ? 'rgba(148,163,184,0.5)' : 'rgba(100,116,139,0.45)'
    const hot = '#fb7185'

    const traceSeverity: Data = {
      type: 'box',
      name: 'Severity',
      y: sev,
      xaxis: 'x',
      yaxis: 'y',
      boxpoints: 'all',
      jitter: 0.35,
      pointpos: -1.75,
      customdata: sevCustom,
      hovertemplate: '<b>Severity %{y}</b><br>%{customdata}<extra></extra>',
      marker: {
        color: sev.map((_, i) => (sevOut[i] ? hot : muted)),
        size: sev.map((_, i) => (sevOut[i] ? 10 : 4)),
        line: { width: 0 },
      },
      fillcolor: isDark ? 'rgba(6,182,212,0.3)' : 'rgba(6,182,212,0.22)',
      line: { color: '#06b6d4', width: 2 },
    }

    const traceDuration: Data = {
      type: 'box',
      name: 'Duration',
      y: dur,
      xaxis: 'x2',
      yaxis: 'y2',
      boxpoints: 'all',
      jitter: 0.35,
      pointpos: -1.75,
      customdata: durCustom,
      hovertemplate: '<b>Duration %{y:.0f} min</b><br>%{customdata}<extra></extra>',
      marker: {
        color: dur.map((_, i) => (durOut[i] ? hot : muted)),
        size: dur.map((_, i) => (durOut[i] ? 10 : 4)),
        line: { width: 0 },
      },
      fillcolor: isDark ? 'rgba(99,102,241,0.3)' : 'rgba(99,102,241,0.22)',
      line: { color: '#6366f1', width: 2 },
    }

    const layout: Partial<Layout> = {
      autosize: true,
      paper_bgcolor: paper,
      plot_bgcolor: plot,
      font: { family: 'Plus Jakarta Sans, system-ui, sans-serif', color: fg, size: 12 },
      margin: { l: 52, r: 56, t: 20, b: 36 },
      showlegend: false,
      dragmode: 'zoom',
      hovermode: 'closest',
      xaxis: {
        domain: [0, 0.46],
        zeroline: false,
        showticklabels: false,
        title: { text: 'Severity', standoff: 10 },
      },
      yaxis: {
        domain: [0, 1],
        title: { text: 'Score (1–10)' },
        zeroline: false,
        gridcolor: grid,
        rangemode: 'tozero',
      },
      xaxis2: {
        domain: [0.54, 1],
        zeroline: false,
        showticklabels: false,
        title: { text: 'Duration', standoff: 10 },
        anchor: 'y2',
      },
      yaxis2: {
        domain: [0, 1],
        title: { text: 'Minutes' },
        anchor: 'x2',
        zeroline: false,
        gridcolor: grid,
        rangemode: 'tozero',
        side: 'right',
      },
    }

    return { data: [traceSeverity, traceDuration], layout }
  }, [filteredEvents, isDark])

  const boxPlotConfig = useMemo(
    (): Partial<Config> => ({
      responsive: true,
      displayModeBar: true,
      displaylogo: false,
      scrollZoom: true,
      doubleClick: 'reset',
      modeBarButtonsToRemove: ['lasso2d', 'select2d'],
    }),
    [],
  )

  const correlationHeatmapFigure = useMemo(() => {
    const n = filteredEvents.length
    const labels = [...CORRELATION_METRIC_LABELS]

    if (n < 2) {
      return { data: [] as Data[], layout: {} as Partial<Layout> }
    }

    const cols = [
      filteredEvents.map((e) => e.severity),
      filteredEvents.map((e) => e.durationMinutes),
      filteredEvents.map((e) => e.dataLossGb),
      filteredEvents.map((e) => e.costKUsd),
    ]
    const z = correlationMatrix(cols)

    const paper = 'rgba(0,0,0,0)'
    const plot = isDark ? '#18181b' : '#fafafa'
    const fg = isDark ? '#e4e4e7' : '#3f3f46'
    const grid = isDark ? '#3f3f46' : '#e4e4e7'
    const mid = isDark ? '#27272a' : '#f1f5f9'

    const trace: Data = {
      type: 'heatmap',
      x: labels,
      y: labels,
      z,
      zmin: -1,
      zmax: 1,
      colorscale: [
        [0, '#1d4ed8'],
        [0.25, '#60a5fa'],
        [0.5, mid],
        [0.75, '#fb923c'],
        [1, '#dc2626'],
      ],
      colorbar: {
        title: {
          text: 'Pearson r',
          side: 'right',
          font: { size: 11, color: fg },
        },
        tickmode: 'linear',
        tick0: -1,
        dtick: 0.25,
        tickfont: { size: 10, color: fg },
        outlinecolor: grid,
        outlinewidth: 1,
        len: 0.92,
        thickness: 16,
        x: 1.02,
      },
      texttemplate: '%{z:.2f}',
      textfont: { size: 11, color: isDark ? '#fafafa' : '#0f172a' },
      hovertemplate:
        '<b>%{y}</b> × <b>%{x}</b><br>r = %{z:.3f}<br><sub>Linear correlation on filtered rows (n=' +
        n +
        ')</sub><extra></extra>',
      xgap: 3,
      ygap: 3,
      showscale: true,
    }

    const layout: Partial<Layout> = {
      autosize: true,
      paper_bgcolor: paper,
      plot_bgcolor: plot,
      font: { family: 'Plus Jakarta Sans, system-ui, sans-serif', color: fg, size: 12 },
      margin: { l: 128, r: 72, t: 48, b: 112 },
      title: {
        text: 'Metric correlation matrix',
        subtitle: {
          text: 'Pairwise Pearson r · −1 (inverse) → 0 (none) → +1 (same direction)',
          font: { size: 11, color: isDark ? '#a1a1aa' : '#64748b' },
        },
        font: { size: 14, color: fg },
        x: 0,
        xanchor: 'left',
        y: 0.98,
        yanchor: 'top',
      },
      xaxis: {
        tickangle: -28,
        tickfont: { size: 10, color: fg },
        side: 'bottom',
        showgrid: false,
        zeroline: false,
      },
      yaxis: {
        autorange: 'reversed',
        tickfont: { size: 10, color: fg },
        showgrid: false,
        zeroline: false,
      },
      annotations: [
        {
          text: 'Row vs column variable',
          xref: 'paper',
          yref: 'paper',
          x: 0,
          y: -0.08,
          xanchor: 'left',
          yanchor: 'top',
          showarrow: false,
          font: { size: 10, color: isDark ? '#a1a1aa' : '#64748b' },
        },
      ],
    }

    return { data: [trace], layout }
  }, [filteredEvents, isDark])

  const exposureRows = useMemo(() => {
    const ing = filteredEvents.filter((e) => e.attackType === 'DDoS' || e.attackType === 'Malware').length
    const cve = filteredEvents.filter((e) => e.attackType === 'Ransomware').length
    const iam = filteredEvents.filter((e) => e.attackType === 'Credential stuffing' || e.attackType === 'Phishing').length
    const total = ing + cve + iam || 1
    return [
      { label: 'Public ingress', pct: Math.round((ing / total) * 100), count: ing },
      { label: 'Unpatched CVEs', pct: Math.round((cve / total) * 100), count: cve },
      { label: 'Over-privileged IAM', pct: Math.round((iam / total) * 100), count: iam },
    ]
  }, [filteredEvents])

  

  const kpiStats = useMemo(() => {
    const n = filteredEvents.length
    const avg = n ? filteredEvents.reduce((s, e) => s + e.severity, 0) / n : 0
    const tb = n ? filteredEvents.reduce((s, e) => s + e.severity * 0.031 + 0.004, 0) : 0
    const freq = new Map<string, number>()
    for (const e of filteredEvents) {
      freq.set(e.attackType, (freq.get(e.attackType) || 0) + 1)
    }
    let topType = '—'
    let topN = 0
    for (const [k, v] of freq) {
      if (v > topN) {
        topN = v
        topType = k
      }
    }
    const topPct = n ? Math.round((topN / n) * 100) : 0
    const corpusPct = allEvents.length ? Math.round((n / allEvents.length) * 100) : 0
    return {
      total: n,
      avgLabel: `${avg.toFixed(1)} / 10`,
      dataLoss: `${tb >= 1000 ? (tb / 1000).toFixed(1) + ' PB' : tb.toFixed(1) + ' TB'}`,
      topType,
      topPct,
      corpusPct,
    }
  }, [allEvents.length, filteredEvents])

  useEffect(() => {
    document.documentElement.classList.toggle('dark', isDark)
  }, [isDark])

  return (
    <div className="min-h-dvh bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100">
      {/* Mobile overlay */}
      {sidebarOpen ? (
        <button
          type="button"
          className="fixed inset-0 z-40 bg-zinc-950/60 backdrop-blur-sm lg:hidden"
          aria-label="Close menu"
          onClick={() => setSidebarOpen(false)}
        />
      ) : null}

      <aside
        className={`fixed inset-y-0 left-0 z-50 flex w-64 flex-col border-r border-zinc-200 bg-white transition-transform dark:border-zinc-800 dark:bg-zinc-900 lg:translate-x-0 ${
          sidebarOpen ? 'translate-x-0' : '-translate-x-full'
        }`}
      >
        <div className="flex h-16 items-center gap-2 border-b border-zinc-200 px-5 dark:border-zinc-800">
          <div className="flex size-9 items-center justify-center rounded-lg bg-gradient-to-br from-cyan-500 to-teal-600 text-white shadow-lg shadow-cyan-500/25">
            <svg className="size-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden>
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" />
            </svg>
          </div>
          <div>
            <p className="text-sm font-semibold tracking-tight">Sentinel</p>
            <p className="text-xs text-zinc-500 dark:text-zinc-400">Security Ops</p>
          </div>
        </div>

        <nav className="flex flex-1 flex-col gap-1 p-3" aria-label="Main">
          {nav.map((item) => {
            const active = activeNav === item.id
            return (
              <button
                key={item.id}
                type="button"
                onClick={() => {
                  setActiveNav(item.id)
                  setSidebarOpen(false)
                }}
                className={`flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-left text-sm font-medium transition ${
                  active
                    ? 'bg-cyan-500/10 text-cyan-700 dark:bg-cyan-500/15 dark:text-cyan-300'
                    : 'text-zinc-600 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800'
                }`}
              >
                <span className={active ? 'text-cyan-600 dark:text-cyan-400' : ''}>{item.icon}</span>
                {item.label}
              </button>
            )
          })}
        </nav>

        <div className="border-t border-zinc-200 p-4 dark:border-zinc-800">
          <div className="rounded-lg border border-zinc-200 bg-zinc-50 p-3 dark:border-zinc-700 dark:bg-zinc-800/50">
            <p className="text-xs font-medium text-zinc-700 dark:text-zinc-200">SOC shift</p>
            <p className="mt-1 text-xs text-zinc-500 dark:text-zinc-400">Tier-2 on call · ETA 4m</p>
          </div>
        </div>
      </aside>

      <div className="lg:pl-64">
        <header className="sticky top-0 z-30 flex h-16 items-center justify-between gap-4 border-b border-zinc-200 bg-zinc-50/80 px-4 backdrop-blur-md dark:border-zinc-800 dark:bg-zinc-950/80 sm:px-6 lg:px-8"> (truncated for brevity)
